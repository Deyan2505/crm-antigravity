# Server
PORT=3000

# Database (PostgreSQL — required)
# Format: postgres://user:password@host:5432/dbname
DATABASE_URL=postgres://user:password@localhost:5432/crm_db

# Authentication (required — use a long random string in production!)
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_a_long_random_string_in_production

# Email — Gmail + App Password (optional, emails are skipped if not set)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Calendly meeting link shown in welcome emails (optional)
CALENDLY_URL=https://calendly.com/your-username

# Make.com Webhook (optional — only needed if you use Make.com automation)
MAKE_CRM_WEBHOOK_URL=https://hook.eu2.make.com/your-webhook-id

# Tally Webhook Signature Secret (optional — recommended for production)
# Find it in your Tally form settings under Webhooks → Signing Secret
TALLY_SIGNING_SECRET=your-tally-signing-secret

# CORS — comma-separated list of allowed frontend origins
# Default: http://localhost:5173,http://localhost:4173
CORS_ORIGIN=https://your-frontend-domain.com
